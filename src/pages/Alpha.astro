---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="game-container">
    <h1 class="level-title">Nivel Alfa</h1>

    <div class="screen">
      <h2 id="math-question">Cargando...</h2>
    </div>

    <div class="fruits-container" id="options-container">
      </div>

    <p id="feedback-message" class="feedback"></p>
  </div>
</Layout>

<style>
  .game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 2rem;
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .level-title {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    background: linear-gradient(135deg, #FF922B, #FFD43B);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(2px 2px 4px rgba(255, 146, 43, 0.3));
  }

  .screen {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    color: #7c2d12;
    padding: 2rem 4rem;
    border-radius: 24px;
    border: 4px solid transparent;
    background-clip: padding-box;
    box-shadow: 
      0 8px 32px rgba(255, 146, 43, 0.2),
      inset 0 0 0 4px rgba(255, 146, 43, 0.3);
    margin-bottom: 2rem;
    min-width: 300px;
    position: relative;
  }

  .screen::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 28px;
    background: linear-gradient(135deg, #FF922B, #FFD43B, #FF6B6B, #CC5DE8);
    z-index: -1;
    animation: borderGlow 3s ease-in-out infinite;
  }

  @keyframes borderGlow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  #math-question {
    font-size: 4rem;
    margin: 0;
    font-family: 'Fredoka', monospace;
    letter-spacing: 5px;
    color: #1e1b4b;
  }

  .fruits-container {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  :global(.fruit-btn) {
    background: linear-gradient(135deg, #FF922B, #FFD43B);
    border: none;
    color: #7c2d12;
    font-size: 2.2rem;
    font-weight: 700;
    padding: 1.2rem 2.5rem;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    min-width: 150px;
    box-shadow: 0 6px 20px rgba(255, 146, 43, 0.3);
    position: relative;
    overflow: hidden;
  }

  :global(.fruit-btn::before) {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, transparent 50%);
    pointer-events: none;
  }

  :global(.fruit-btn:hover) {
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 12px 30px rgba(255, 146, 43, 0.5);
  }

  :global(.fruit-btn:active) {
    transform: translateY(-2px) scale(0.98);
  }

  .feedback {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 2rem;
    min-height: 2rem;
  }

  :global(.correct) {
    color: #16a34a;
    animation: correctPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(.incorrect) {
    color: #ef4444;
    animation: shake 0.5s ease;
  }

  @keyframes correctPop {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }
</style>

<script>
  const questionEl = document.getElementById('math-question');
  const optionsContainer = document.getElementById('options-container');
  const feedbackEl = document.getElementById('feedback-message');

  function generateQuestion() {
    let var1 = Math.floor(Math.random() * 15) + 1;
    let var2 = Math.floor(Math.random() * 15) + 1;

    const isAddition = Math.random() > 0.5;

    if (!isAddition && var1 < var2) {
      let temp = var1;
      var1 = var2;
      var2 = temp;
    }

    const correctAnswer = isAddition ? (var1 + var2) : (var1 - var2);
    const operator = isAddition ? '+' : '-';

    let wrong1 = correctAnswer + Math.floor(Math.random() * 3) + 1;
    if (wrong1 === correctAnswer) wrong1 += 1;

    // Solo 2 opciones para Alfa
    const options = [
      { value: correctAnswer, isCorrect: true },
      { value: wrong1, isCorrect: false }
    ];

    options.sort(() => Math.random() - 0.5);

    if (questionEl) {
      questionEl.textContent = `${var1} ${operator} ${var2} = ?`;
    }

    renderOptions(options);
  }

  function renderOptions(options: { value: number; isCorrect: boolean }[]) {
    if (!optionsContainer) return;
    optionsContainer.innerHTML = '';

    const labels = ['A', 'B'];

    options.forEach((opt, index) => {
      const btn = document.createElement('button');
      btn.className = 'fruit-btn';
      btn.textContent = `Opción ${labels[index]}: ${opt.value}`;

      btn.addEventListener('click', () => {
        checkAnswer(opt.isCorrect);
      });

      optionsContainer.appendChild(btn);
    });
  }

  function checkAnswer(isCorrect: boolean) {
    if (!feedbackEl) return;

    if (isCorrect) {
      feedbackEl.textContent = "¡Correcto!";
      feedbackEl.className = "feedback correct";

      setTimeout(() => {
        feedbackEl.textContent = "";
        generateQuestion();
      }, 1500);

    } else {
      feedbackEl.textContent = "Intenta de nuevo";
      feedbackEl.className = "feedback incorrect";
    }
  }

  generateQuestion();
</script>
