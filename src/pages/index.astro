---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="home-container">
    <div class="welcome-badge">¡Hora de jugar!</div>

    <h1 class="main-title">Bienvenido al Juego Matemático <br/> <span class="highlight">Serpientes y Escaleras</span></h1>

    <div class="intro-box">
      <p>¡Prepárate para una aventura llena de diversión y matemáticas! En este juego, cada casilla tiene un desafío matemático que debes resolver para avanzar. ¡Buena suerte!</p>
    </div>

    <div class="level-selection">
      <a href="/Alpha" class="level-card alfa-card">
        <span class="card-title">Nivel Alfa</span>
        <span class="card-desc">Sumas y Restas (6-8 años)</span>
        <span class="card-arrow">→</span>
      </a>
      <a href="/Beta" class="level-card beta-card">
        <span class="card-title">Nivel Beta</span>
        <span class="card-desc">Multiplicación y División (9-12 años)</span>
        <span class="card-arrow">→</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  .home-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 1rem;
    padding: 1rem;
  }

  .welcome-badge {
    background: linear-gradient(135deg, #FF6B6B, #CC5DE8);
    color: #fff;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    animation: bounceIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(204, 93, 232, 0.4);
  }

  @keyframes bounceIn {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .main-title {
    color: #1e1b4b;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.3;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
  }

  .highlight {
    background: linear-gradient(90deg, #FF6B6B, #FF922B, #FFE066, #51CF66, #339AF0, #CC5DE8);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: rainbowShift 3s linear infinite;
    font-weight: 700;
  }

  @keyframes rainbowShift {
    0% { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .intro-box {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(10px);
    color: #374151;
    padding: 2rem;
    border-radius: 24px;
    border: 3px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    max-width: 700px;
    font-size: 1.15rem;
    line-height: 1.7;
    margin-bottom: 3rem;
  }


  .level-selection {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .level-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem 2.5rem;
    border-radius: 24px;
    min-width: 220px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .level-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, transparent 100%);
    pointer-events: none;
  }

  .level-card:hover {
    transform: translateY(-10px) scale(1.03);
  }

  .alfa-card {
    background: linear-gradient(135deg, #FF922B, #FFD43B);
    color: #7c2d12;
    box-shadow: 0 8px 25px rgba(255, 146, 43, 0.35);
  }

  .alfa-card:hover {
    box-shadow: 0 16px 40px rgba(255, 146, 43, 0.5);
  }

  .beta-card {
    background: linear-gradient(135deg, #22D3EE, #3B82F6);
    color: #fff;
    box-shadow: 0 8px 25px rgba(59, 130, 246, 0.35);
  }

  .beta-card:hover {
    box-shadow: 0 16px 40px rgba(59, 130, 246, 0.5);
  }


  .card-title {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .card-desc {
    font-size: 0.95rem;
    opacity: 0.85;
  }

  .card-arrow {
    font-size: 1.5rem;
    margin-top: 0.3rem;
    transition: transform 0.3s ease;
  }

  .level-card:hover .card-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 600px) {
    .main-title {
      font-size: 1.8rem;
    }
    .level-card {
      min-width: unset;
      width: 100%;
    }
  }
</style>
