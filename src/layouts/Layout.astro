---
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';

interface Props {
  isHome?: boolean;
  showLevelButtons?: boolean;
}

const { isHome = false, showLevelButtons = false } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Juego Matemático - UTVAM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class={isHome ? 'home' : ''}>

    <Navbar showLevelButtons={showLevelButtons} />

    <main class="container">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  * {
    font-family: 'Fredoka', 'Comic Sans MS', cursive, sans-serif;
  }

  html, body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: url('/4.jpeg') center/cover no-repeat fixed;
    background-attachment: fixed;
    overflow-x: hidden;
  }

  .container {
    flex: 1;
    width: 100%;
    max-width: 1000px;
    margin: 2rem auto;
    padding: 0 1rem;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
  }



  @keyframes floatAround {
    0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
    25% { transform: translate(20px, -30px) rotate(90deg) scale(1.1); }
    50% { transform: translate(-15px, 20px) rotate(180deg) scale(0.9); }
    75% { transform: translate(25px, 10px) rotate(270deg) scale(1.05); }
  }
</style>
