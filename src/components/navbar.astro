---
const { showLevelButtons = false } = Astro.props;
---

<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="logo">
      <span class="logo-text">El juego de La Oca</span>
    </a>

    {showLevelButtons ? (
      <div class="nav-links">
        <a href="/Alpha" class="link alfa">Nivel Alfa</a>
        <a href="/Beta" class="link beta">Nivel Beta</a>
      </div>
    ) : null}
  </div>
</nav>

<style>
  .navbar {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.14), inset 0 1px 2px rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.35);
    padding: 1.2rem 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom-left-radius: 24px;
    border-bottom-right-radius: 24px;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;
  }

  .logo:hover {
    transform: scale(1.08);
    filter: drop-shadow(0 4px 12px rgba(124, 58, 237, 0.3));
  }

  .logo-text {
    color: #1F1035;
    font-weight: 900;
    text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.6), 0 0 20px rgba(124, 58, 237, 0.2);
    letter-spacing: 0.5px;
  }

  .nav-links {
    display: flex;
    gap: 12px;
    margin-left: auto;
  }

  .link {
    text-decoration: none;
    padding: 0.8rem 1.8rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    border: 2px solid transparent;
    position: relative;
    overflow: hidden;
  }

  .link:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
  }

  .alfa {
    background: linear-gradient(135deg, #FF6B35, #FF8C42);
    color: #fff;
    box-shadow: 0 6px 20px rgba(255, 107, 53, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.2);
  }

  .alfa:hover {
    box-shadow: 0 12px 35px rgba(255, 107, 53, 0.6);
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .beta {
    background: linear-gradient(135deg, #3B82F6, #0EA5E9, #22D3EE);
    color: #fff;
    box-shadow: 0 6px 20px rgba(56, 189, 248, 0.45);
    border: 2px solid rgba(255, 255, 255, 0.25);
  }

  .beta:hover {
    box-shadow: 0 12px 35px rgba(56, 189, 248, 0.65);
    border: 2px solid rgba(255, 255, 255, 0.55);
  }

  @media (max-width: 600px) {
    .nav-container {
      flex-direction: column;
      gap: 1rem;
    }

    .nav-links {
      flex-direction: column;
      width: 100%;
      align-items: center;
    }
  }
</style>
