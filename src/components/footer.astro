---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <p class="utvam-text">
      Desarrollado por Ingeniería en Desarrollo y Gestión de Software
    </p>
    <p class="utvam-title">
      <strong>UTVAM</strong>
    </p>
    <p class="sub-text">
      Universidad Tecnológica de la Zona Metropolitana del Valle de México &copy; {currentYear}
    </p>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(135deg, #1e1b4b, #312e81, #4c1d95);
    color: #e0e7ff;
    padding: 2.5rem 1rem;
    text-align: center;
    border-top: 4px solid transparent;
    border-image: linear-gradient(90deg, #FF6B6B, #FFE066, #51CF66, #339AF0, #CC5DE8) 1;
    margin-top: auto;
    position: relative;
    z-index: 1;
  }


  .footer-content {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .utvam-text {
    font-size: 1rem;
    margin: 0;
    color: #c7d2fe;
  }

  .utvam-title {
    font-size: 1.6rem;
    margin: 5px 0;
    letter-spacing: 3px;
  }

  .utvam-title strong {
    background: linear-gradient(90deg, #FFE066, #FF922B, #FF6B6B, #CC5DE8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 8px rgba(255, 146, 43, 0.4));
  }

  .sub-text {
    font-size: 0.85rem;
    color: #a5b4fc;
    margin: 0;
  }
</style>
